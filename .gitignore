# Applies to all three apps in this repo: frontend-website/, frontend-admin/, backend/
# (patterns are unanchored, so they match at any depth)

# Dependencies
node_modules

# Build output
dist
dist-ssr
build
*.tsbuildinfo

# Env / secrets
.env
.env.local
.env.*.local
*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
